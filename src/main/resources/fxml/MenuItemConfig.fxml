<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="100" minWidth="100" prefHeight="400.0" prefWidth="600.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.restaurant.KDS.controller.menuItem.MenuItemConfigController">
   <top>
      <HBox alignment="CENTER" prefHeight="50.0" style="-fx-padding: 10 20 10 20; -fx-background-color: #433a3f;" BorderPane.alignment="CENTER">
         <children>
            <Label style="-fx-font-size: 24; -fx-text-fill: white;" styleClass="titleLabel" text="Menu Items" />
            <Button minWidth="40" mnemonicParsing="false" onAction="#onAddMenuItem" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 24; -fx-padding: 0; -fx-text-fill: white;" text="+">
               <font>
                  <Font size="24.0" />
               </font></Button>
         </children>
      </HBox>
   </top>
   <center>
      <TableView fx:id="menuItemTableView" prefHeight="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
          <TableColumn fx:id="nameColumn" prefWidth="107.33334350585938" text="Name" />
            <TableColumn fx:id="categoryColumn" prefWidth="116.6666259765625" text="Category" />
            <TableColumn fx:id="availableColumn" prefWidth="143.3333740234375" text="Available" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
</BorderPane>
