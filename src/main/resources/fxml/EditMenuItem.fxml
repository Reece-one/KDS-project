<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<ScrollPane hbarPolicy="NEVER" prefHeight="517.0" prefWidth="603.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.restaurant.KDS.controller.menuItem.EditMenuItemController">
   <content>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0">
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minWidth="-Infinity" styleClass="titleLabel" text="Edit Item" />
            <TextField fx:id="nameTextField" promptText="Name">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="priceTextField" promptText="Price(£)">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="categoryTextField" promptText="Category">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </TextField>
            <HBox prefHeight="33.0" prefWidth="600.0">
               <children>
                  <TextField fx:id="ingredientTextField" promptText="Ingredients">
                     <HBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onAction="#addIngredient" text="Add" />
               </children>
            </HBox>
            <FlowPane fx:id="ingredientsFlowPane" prefHeight="32.0" prefWidth="600.0">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </FlowPane>
            <HBox prefHeight="33.0" prefWidth="600.0">
               <children>
                  <TextField fx:id="allergenTextField" promptText="Allergens">
                     <HBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onAction="#addAllergen" text="Add" />
               </children>
            </HBox>
            <FlowPane fx:id="allergensFlowPane" prefHeight="31.0" prefWidth="600.0">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </FlowPane>
            <Label text="Stations">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <FlowPane fx:id="stationFlowPane" prefHeight="31.0" prefWidth="600.0">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </FlowPane>
            <CheckBox fx:id="availableCheckBox" mnemonicParsing="false" text="Available?">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </CheckBox>
            <TextField fx:id="timeTextField" promptText="Prep Time (Minutes)">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </TextField>
            <HBox alignment="CENTER_RIGHT" spacing="10">
               <Button mnemonicParsing="false" onAction="#onDelete" styleClass="secondary-button" text="Delete">
                  <HBox.margin>
                     <Insets />
                  </HBox.margin>
               </Button>
               <Button mnemonicParsing="false" onAction="#onSave" text="Save">
                  <HBox.margin>
                     <Insets right="30.0" />
                  </HBox.margin>
               </Button>
            </HBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
